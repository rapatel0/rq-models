# rq-models vLLM substrate — Sprint 004
#
# Overlay strategy: base on the pre-built upstream vLLM v0.19.1 image and
# patch our Phase 1 RotorQuant changes on top. Phase 1 changes are pure
# Python (4 modified files + 1 new module), so source-rebuilding vLLM is
# unnecessary at this phase. When Phase 2 lands real CUDA kernels we'll
# extend this Dockerfile to build them as a torch extension.
#
# Why overlay vs source build: the source-build path hit a python3.12
# post-install SIGSEGV on this dev box (zfs container interaction), and
# the upstream-published image works around all of that since vLLM's CI
# already ran it. Faster build, fewer environment variables.
#
# Build:
#   docker build -t rq-vllm:phase1 -f docker/Dockerfile.vllm .
#
# Supported GPUs: anything from sm_70 (V100) onward.
# - vllm/vllm-openai:v0.19.1 ships CUDA 12.9.86 which retains sm_70 + sm_75
#   support, so V100 / T4 / A100 / A10G / RTX 4090 / H100 / RTX 5090 all
#   build and run.
# - For CUDA 13.x base image (vllm/vllm-openai:v0.19.1-cu130-ubuntu2404),
#   sm_70 + sm_75 are dropped — V100 / T4 are not supported. The kernel
#   JIT-build auto-detects supported arches via `nvcc --list-gpu-arch`,
#   so you don't have to hand-edit anything.
#
# Override the base image to pin CUDA 13:
#   docker build --build-arg VLLM_VERSION=v0.19.1-cu130-ubuntu2404 \
#                -t rq-vllm:phase1-cu13 -f docker/Dockerfile.vllm .
#
# Run (small model, single 24 GB GPU smoke):
#   docker run --gpus all -p 8080:8080 \
#     -e MODEL=Qwen/Qwen3-4B \
#     -v ~/.cache/huggingface:/root/.cache/huggingface \
#     rq-vllm:phase1
#
# Phase 1 success criterion (see docs/SPRINT-004-PHASE1-VALIDATION.md):
# generation with --kv-cache-dtype rotorquant_planar3 produces
# bit-identical tokens to --kv-cache-dtype float16 on the same prompt
# at temperature=0, seed=42.

ARG VLLM_VERSION=v0.19.1
FROM vllm/vllm-openai:${VLLM_VERSION}

# rq-vllm fork commit SHA baked in for traceability. Update when the
# overlay patches change.
ARG RQ_VLLM_COMMIT=e04001ae3
RUN echo "${RQ_VLLM_COMMIT}" > /etc/rq-vllm-commit

# Overlay Phase 1 + 2c RotorQuant patches onto the base image's installed vLLM.
# Path is fixed for vllm/vllm-openai:v0.19.1 (Ubuntu 24.04 + Python 3.12).
# If vLLM is reinstalled at a different path in a future tag, update VLLM_PATH.
ARG VLLM_PATH=/usr/local/lib/python3.12/dist-packages/vllm
COPY docker/rq_vllm_overlay/config/cache.py ${VLLM_PATH}/config/cache.py
COPY docker/rq_vllm_overlay/utils/torch_utils.py ${VLLM_PATH}/utils/torch_utils.py
COPY docker/rq_vllm_overlay/v1/attention/backends/flash_attn.py ${VLLM_PATH}/v1/attention/backends/flash_attn.py
COPY docker/rq_vllm_overlay/v1/attention/ops/rotorquant_kv.py ${VLLM_PATH}/v1/attention/ops/rotorquant_kv.py

# Phase 2a CUDA kernels: JIT-compiled by the rotorquant_kv module on first
# import. The base image already has nvcc + CUDA toolkit at /usr/local/cuda
# so no apt installs needed. Bake the kernel sources into the image at the
# location rotorquant_kv.py expects to find them (vllm root + csrc/).
ARG VLLM_ROOT=/usr/local/lib/python3.12/dist-packages
COPY docker/rq_vllm_overlay/csrc/attention/rotorquant/ ${VLLM_ROOT}/vllm/csrc/attention/rotorquant/

COPY docker/entrypoint.vllm.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8080
ENTRYPOINT ["/entrypoint.sh"]
