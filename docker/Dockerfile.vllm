# rq-models vLLM substrate — Sprint 004 Phase 0 scaffold
#
# Builds the rapatel0/rq-vllm fork (pinned to upstream v0.19.1, working
# branch feature/rotorquant) into a runnable OpenAI-compatible server
# image. Phase 0 ships this with no RotorQuant kernel changes — used to
# verify the vLLM serving path before any quant work lands.
#
# Build:
#   docker build -t rq-vllm -f docker/Dockerfile.vllm .
#
# Build with override branch / commit:
#   docker build \
#     --build-arg RQ_VLLM_BRANCH=feature/rotorquant \
#     --build-arg RQ_VLLM_COMMIT=98b61e668 \
#     -t rq-vllm -f docker/Dockerfile.vllm .
#
# Run (Qwen3-27B f16 baseline on RTX 5090):
#   docker run --gpus all -p 8080:8080 \
#     -e MODEL=Qwen/Qwen3-27B \
#     -v ~/.cache/huggingface:/root/.cache/huggingface \
#     rq-vllm
#
# Phase 0 success criterion: /v1/chat/completions returns sensible tokens
# from Qwen3-27B with no RotorQuant config. Establishes that the substrate
# itself works.

# ============================================================================
# Build stage: build vLLM from our fork at the pinned tag/commit
# ============================================================================
ARG CUDA_VERSION=12.9.1
FROM nvidia/cuda:${CUDA_VERSION}-devel-ubuntu22.04 AS build

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates \
        python3.12 python3.12-venv python3.12-dev python3-pip \
        build-essential cmake ninja-build \
    && rm -rf /var/lib/apt/lists/*

RUN python3.12 -m venv /opt/venv
ENV PATH="/opt/venv/bin:${PATH}"
RUN pip install --upgrade pip wheel setuptools

# Pin the rq-vllm fork. RQ_VLLM_COMMIT is optional; if unset, branch HEAD is used.
ARG RQ_VLLM_BRANCH=feature/rotorquant
ARG RQ_VLLM_COMMIT=

RUN git clone https://github.com/rapatel0/rq-vllm.git /src \
 && cd /src \
 && git checkout ${RQ_VLLM_BRANCH} \
 && if [ -n "${RQ_VLLM_COMMIT}" ]; then git checkout ${RQ_VLLM_COMMIT}; fi \
 && git rev-parse HEAD > /src/RQ_VLLM_COMMIT_SHA

WORKDIR /src

# Pre-install torch matching vLLM v0.19.1's expectations to avoid pip
# resolving an incompatible nightly. vLLM v0.19.1 targets torch 2.5.x.
RUN pip install --no-cache-dir 'torch>=2.5.0,<2.6.0' \
 && pip install --no-cache-dir --no-build-isolation -e .

# ============================================================================
# Runtime stage
# ============================================================================
ARG CUDA_VERSION
FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 ca-certificates curl libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=build /opt/venv /opt/venv
COPY --from=build /src /src
ENV PATH="/opt/venv/bin:${PATH}"

# Capture the rq-vllm commit hash baked into the image for traceability.
RUN cp /src/RQ_VLLM_COMMIT_SHA /etc/rq-vllm-commit
RUN cat /etc/rq-vllm-commit

COPY docker/entrypoint.vllm.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8080
ENTRYPOINT ["/entrypoint.sh"]
